YOUTUBE_KANAAL_ENV=development
YOUTUBE_KANAAL_DEBUG=false
MOCK_MODE=false

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b-instruct

PEXELS_API_KEY=

YOUTUBE_CLIENT_SECRET_PATH=./data/credentials/client_secret.json
YOUTUBE_TOKEN_PATH=./data/credentials/youtube_token.json
DEFAULT_PRIVACY_STATUS=private

FFMPEG_BINARY=ffmpeg
PIPER_BINARY=piper
DEFAULT_PIPER_VOICE=en_US-john-medium
PIPER_VOICE_MODEL_PATH=./cache/piper/en_US-john-medium.onnx
PIPER_LENGTH_SCALE=1.0
PIPER_NOISE_SCALE=0.667
PIPER_NOISE_W_SCALE=0.8
PIPER_SENTENCE_SILENCE=0.12

WHISPER_CPP_BINARY=whisper-cli
WHISPER_MODEL_PATH=./cache/whisper/ggml-base.en.bin

OUTPUT_DIR=./output
CACHE_DIR=./cache
DATA_DIR=./data
LOGS_DIR=./logs
DATABASE_PATH=./data/youtube_kanaal.db
DOWNLOADS_DIR=~/Downloads

NETWORK_TIMEOUT_SECONDS=30
OLLAMA_TIMEOUT_SECONDS=180
RETRY_ATTEMPTS=3
ALLOW_PLACEHOLDER_VIDEO=false
PEXELS_RESULTS_PER_QUERY=12
SIMILARITY_THRESHOLD=0.86
MIN_SHORT_DURATION_SECONDS=20
MAX_SHORT_DURATION_SECONDS=35

SUBTITLE_FONT_NAME=Arial
SUBTITLE_FONT_SIZE=48
SUBTITLE_MARGIN_V=640
SUBTITLE_OUTLINE=5
SUBTITLE_PRIMARY_COLOR=&H00FFFFFF
SUBTITLE_HIGHLIGHT_COLOR=&H006BFF7C
SUBTITLE_OUTLINE_COLOR=&H00000000
SUBTITLE_BACK_COLOR=&H64000000
